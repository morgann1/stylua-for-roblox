--[[
	Codegen Command

	Runs all code generation tasks: compiles networking, generates project links,
	and generates the sourcemap.
]]

local fs = require("@lute/fs")
local process = require("@lute/process")

local color = require("../utils/color")
local rojo = require("../lib/project/rojo")

local codegen = {}

-- Metadata for help command
codegen.name = "codegen"
codegen.description = "Runs all code generation (sourcemap only for now)"
codegen.usage = "lute run codegen"

-- Argument definitions for CLI parsing
codegen.arguments = {}

export type Options = {
	quiet: boolean?,
	dev: boolean?,
	generateSourcemap: boolean?,
}

local BUILD_CONFIG_PATH = "plugin/generated/buildConfig.luau"
local WALLY_TOML_PATH = "plugin/wally.toml"
local CHANGELOG_SRC_PATH = "CHANGELOG.md"
local CHANGELOG_OUT_PATH = "plugin/generated/changelog.luau"

local function readPluginVersion(): string
	local handle = fs.open(WALLY_TOML_PATH, "r")
	local contents = fs.read(handle)
	fs.close(handle)

	local version = contents:match('version%s*=%s*"([^"]+)"')
	assert(version, `Could not parse version from {WALLY_TOML_PATH}`)
	return version
end

local function readCommitSha(): string
	-- Outside of git (e.g. in a published tarball) we fall back to an empty
	-- string so the About screen can render the version alone.
	local result = process.run({ "git", "rev-parse", "--short", "HEAD" })
	if not result.ok then
		return ""
	end
	return (result.stdout:gsub("%s+$", ""))
end

local function buildConfig(dev: boolean, version: string, commit: string): { [string]: string }
	-- Embed the version in widget titles so dock state persists per version,
	-- matching Rojo's convention (e.g. `widget.Title = "Rojo x.y.z"`).
	local suffix = if dev then " (Dev)" else ""
	local widgetTitle = `Discover {version}{suffix}`

	return {
		pluginName = `Discover{suffix}`,
		widgetId = widgetTitle,
		widgetTitle = widgetTitle,
		widgetName = widgetTitle,
		buttonId = if dev then "discover-dev" else "discover",
		buttonTitle = `Discover{suffix}`,
		buttonTooltip = if dev
			then "Browse and install Luau packages (dev build)"
			else "Browse and install Luau packages",
		peerId = if dev then "morgann1/studio-discover-dev" else "morgann1/studio-discover",
		toolbarTitle = if dev then "22:43 (Dev)" else "22:43",
		mediumName = if dev then "  22:43 Plugin Suite (Dev)" else "  22:43 Plugin Suite",
		icon = if dev then "rbxassetid://132814924850541" else "rbxassetid://125842588490194",
		commit = commit,
	}
end

local function isDir(path: string): boolean
	return fs.exists(path) and fs.type(path) == "dir"
end

local function quote(value: string): string
	-- Escape backslashes and quotes, then wrap in double quotes.
	local escaped = value:gsub("\\", "\\\\"):gsub('"', '\\"')
	return `"{escaped}"`
end

local function serializeConfig(config: { [string]: string }, dev: boolean): string
	local keys = {
		"pluginName",
		"widgetId",
		"widgetTitle",
		"widgetName",
		"buttonId",
		"buttonTitle",
		"buttonTooltip",
		"peerId",
		"toolbarTitle",
		"mediumName",
		"icon",
		"commit",
	}

	local lines = {
		"--!strict",
		"-- This file is @generated by `lute run codegen` / `lute run build`. Do not edit.",
		"",
		"return table.freeze({",
		"\tisDev = " .. (if dev then "true" else "false") .. ",",
	}

	for _, key in keys do
		table.insert(lines, "\t" .. key .. " = " .. quote(config[key]) .. ",")
	end

	table.insert(lines, "})")
	table.insert(lines, "")

	return table.concat(lines, "\n")
end

local function writeBuildConfig(dev: boolean)
	if not isDir("plugin/generated") then
		fs.mkdir("plugin/generated")
	end

	local version = readPluginVersion()
	local commit = readCommitSha()
	local config = buildConfig(dev, version, commit)
	local source = serializeConfig(config, dev)

	local handle = fs.open(BUILD_CONFIG_PATH, "w")
	fs.write(handle, source)
	fs.close(handle)
end

local function pickLongBracket(body: string): string
	-- Pick the shortest `=` run such that the closing delimiter doesn't appear
	-- inside the body. CHANGELOG.md rarely contains `]==]`, but we scan to be
	-- robust.
	local level = 0
	while body:find(`]{string.rep("=", level)}]`, 1, true) ~= nil do
		level += 1
	end
	return string.rep("=", level)
end

local function stripChangelogPreamble(body: string): string
	-- Drop everything before the first `## ` heading so the in-plugin view
	-- skips the Keep-a-Changelog / Semantic-Versioning boilerplate.
	local firstRelease = body:find("\n## ", 1, true)
	if firstRelease == nil then
		return body
	end
	return body:sub(firstRelease + 1)
end

local function stripLinks(body: string): string
	-- Remove every external URL from the bundled changelog: collapse inline
	-- `[label](url)` to `label`, and drop reference-style definitions like
	-- `[3.7.0]: https://github.com/...` entirely.
	local out = body:gsub("%[([^%]]+)%]%b()", "%1")
	local lines: { string } = {}
	for line in (out .. "\n"):gmatch("([^\n]*)\n") do
		if line:match("^%[[^%]]+%]:%s") == nil then
			table.insert(lines, line)
		end
	end
	return (table.concat(lines, "\n"):gsub("\n+$", "\n"))
end

local function writeChangelog()
	if not isDir("plugin/generated") then
		fs.mkdir("plugin/generated")
	end

	local body = ""
	if fs.exists(CHANGELOG_SRC_PATH) then
		local handle = fs.open(CHANGELOG_SRC_PATH, "r")
		body = fs.read(handle)
		fs.close(handle)
	end

	body = stripChangelogPreamble(body)
	body = stripLinks(body)

	local bracket = pickLongBracket(body)
	local source = table.concat({
		"--!strict",
		"-- This file is @generated by `lute run codegen` / `lute run build`. Do not edit.",
		"",
		`return [{bracket}[`,
		body,
		`]{bracket}]`,
		"",
	}, "\n")

	local handle = fs.open(CHANGELOG_OUT_PATH, "w")
	fs.write(handle, source)
	fs.close(handle)
end

--[[
	Runs all code generation tasks.

	@param options Configuration options
	@return True if successful, false otherwise
]]
function codegen.run(options_: Options?): boolean
	local options: Options = options_ or {}
	local quiet = if options.quiet ~= nil then options.quiet else false
	local dev = if options.dev ~= nil then options.dev else false

	writeBuildConfig(dev)
	writeChangelog()

	if options.generateSourcemap then
		-- Generate sourcemap
		local sourcemapSuccess, sourcemapError = rojo.sourcemap({
			projectFile = "plugin/default.project.json",
			output = "plugin/generated/sourcemap.json",
			absolute = true,
		})
		if not sourcemapSuccess then
			if not quiet then
				print(color.bold(color.red("Failed to generate sourcemap")))
				print(sourcemapError)
			end
			return false
		end

		if not quiet then
			print(color.bold(color.dim("Sourcemap generated successfully!")))
		end
	end

	if not quiet then
		print(color.bold(color.green("Code generation complete!")))
	end

	return true
end

return codegen
