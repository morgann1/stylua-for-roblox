{
	"language": {
		"mode": "strict"
	},
	"lint": {
		"DeprecatedGlobal": "fatal",
		"FunctionUnused": "fatal",
		"GlobalUsedAsLocal": "fatal",
		"ImplicitReturn": "fatal",
		"ImportUnused": "fatal",
		"LocalShadow": "fatal",
		"LocalUnused": "fatal",
		"MultiLineStatement": "fatal",
		"SameLineStatement": "fatal",
		"UnknownGlobal": "fatal"
	}
}